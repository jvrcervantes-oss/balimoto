# Bloquea acceso web directo a ficheros sensibles (Apache 2.4 y 2.2)
<FilesMatch "^(\.passhash|config\.php|throttle\.php)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>
